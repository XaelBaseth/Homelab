services:
  gluetun:
    image: {{ gluetun_image }}
    container_name: gluetun
    cap_add:
      - NET_ADMIN
    devices:
      - /dev/net/tun:/dev/net/tun
    environment:
      - VPN_SERVICE_PROVIDER=cyberghost
      - VPN_TYPE=openvpn
      - OPENVPN_USER=${OPENVPN_USER}
      - OPENVPN_PASSWORD=${OPENVPN_PASSWORD}
      - SERVER_COUNTRIES=${SERVER_COUNTRIES}
      - TZ=${TZ}
    ports:
      - 8080:8080         # qBittorrent WebUI (published here, not on qbit — see note)
      - 6881:6881         # torrent TCP
      - 6881:6881/udp     # torrent UDP
    volumes:
      - ${APPDATA}/gluetun:/gluetun
    restart: unless-stopped

  qbittorrent:
    image: {{ qbittorrent_image }}
    container_name: qbittorrent
    network_mode: "service:gluetun"     # ALL qBittorrent traffic routes through the VPN
    depends_on:
      gluetun:
        condition: service_healthy
    environment:
      - PUID=${PUID}
      - PGID=${PGID}
      - TZ=${TZ}
      - WEBUI_PORT=8080
    volumes:
      - ${APPDATA}/qbittorrent:/config
      - ${MEDIA}:/data                   # whole /data mounted so hardlinks work later
    restart: unless-stopped

  prowlarr:
    image: {{ prowlarr_image }}
    container_name: prowlarr
    environment:
      - PUID=${PUID}
      - PGID=${PGID}
      - TZ=${TZ}
    ports:
      - 9696:9696
    volumes:
      - ${APPDATA}/prowlarr:/config
    restart: unless-stopped

  sonarr:
    image: {{ sonarr_image }}
    container_name: sonarr
    environment:
      - PUID=${PUID}
      - PGID=${PGID}
      - TZ=${TZ}
    ports:
      - 8989:8989
    volumes:
      - ${APPDATA}/sonarr:/config
      - ${MEDIA}:/data
    restart: unless-stopped

  radarr:
    image: {{ radarr_image }}
    container_name: radarr
    environment:
      - PUID=${PUID}
      - PGID=${PGID}
      - TZ=${TZ}
    ports:
      - 7878:7878
    volumes:
      - ${APPDATA}/radarr:/config
      - ${MEDIA}:/data
    restart: unless-stopped

  bazarr:
    image: {{ bazarr_image }}
    container_name: bazarr
    environment:
      - PUID=${PUID}
      - PGID=${PGID}
      - TZ=${TZ}
    ports:
      - 6767:6767
    volumes:
      - ${APPDATA}/bazarr:/config
      - ${MEDIA}:/data
    restart: unless-stopped

  jellyfin:
    image: {{ jellyfin_image }}
    container_name: jellyfin
    environment:
      - PUID=${PUID}
      - PGID=${PGID}
      - TZ=${TZ}
    group_add:
      - "{{ jellyfin_render_gid }}"   # render — Quick Sync (renderD128)
      - "{{ jellyfin_video_gid }}"    # video
    devices:
      - /dev/dri:/dev/dri
    ports:
      - 8096:8096
    volumes:
      - ${APPDATA}/jellyfin:/config
      - ${MEDIA}/media:/data/media
    restart: unless-stopped

  jellyseerr:
    image: {{ jellyseerr_image }}
    container_name: jellyseerr
    environment:
      - TZ=${TZ}
    ports:
      - 5055:5055
    volumes:
      - ${APPDATA}/jellyseerr:/app/config
    restart: unless-stopped

  maintainerr:
    image: {{ maintainerr_image }}
    container_name: maintainerr
    environment:
      - TZ=${TZ}
    ports:
      - 6246:6246
    volumes:
      - ${APPDATA}/maintainerr:/opt/data
    restart: unless-stopped

  npm:
    image: {{ npm_image }}
    container_name: npm
    ports:
      - 80:80         # http (where all *.home traffic lands)
      - 443:443       # https (unused for now, reserved)
      - 81:81         # NPM admin UI
    volumes:
      - ${APPDATA}/npm/data:/data
      - ${APPDATA}/npm/letsencrypt:/etc/letsencrypt
    restart: unless-stopped
