server:
  assets-path: /app/assets   # served at /assets/ — holds custom.css

theme:
  custom-css-file: /assets/custom.css

pages:
  # ══ Page 1: Home — status, launcher, what's new ══════════════
  - name: Home
    columns:
      # ── Left: at-a-glance status ──
      - size: small
        widgets:
          - type: clock
            hour-format: 24h

          - type: weather
            location: Le Havre, France
            units: metric
            hour-format: 24h

          - type: server-stats
            servers:
              - type: local
                name: Beelink
                hide-mountpoints-by-default: false
                mountpoints:
                  /mnt/host/data:
                    name: Media
                  /mnt/host/home:
                    name: Apps

      # ── Center: launcher ──
      # NOTE: links use the Beelink IP:port (works today). At the OPNsense/DNS
      # phase, swap {{ vault_beelink_host }}:PORT for the *.home names (see Roadmap).
      - size: full
        widgets:
          - type: split-column
            css-class: bookmarks-2col
            widgets:
              - type: bookmarks
                groups:
                  - title: Media
                    links:
                      - title: Jellyfin
                        url: http://{{ vault_beelink_host }}:8096
                        icon: di:jellyfin
                      - title: Seerr
                        url: http://{{ vault_beelink_host }}:5055
                        icon: di:seerr
                      - title: Audiobookshelf
                        url: http://{{ vault_beelink_host }}:13378
                        icon: di:audiobookshelf
              - type: bookmarks
                groups:
                  - title: Monitoring
                    links:
                      - title: Uptime Kuma
                        url: http://{{ vault_beelink_host }}:3001
                        icon: di:uptime-kuma
                      - title: Beszel
                        url: http://{{ vault_beelink_host }}:8090
                        icon: di:beszel
                  - title: Administration
                    links:
                      - title: Dozzle
                        url: http://{{ vault_beelink_host }}:8888
                        icon: di:dozzle
                      - title: Dockge
                        url: http://{{ vault_beelink_host }}:5001
                        icon: di:dockge
                      # Watchtower runs headless (notify-only) — no web UI, so no link
                  - title: Infra
                    links:
                      - title: Nginx Proxy Manager
                        url: http://{{ vault_beelink_host }}:81
                        icon: di:nginx-proxy-manager

      - size: small
        widgets:
          - type: releases
            title: App Releases
            cache: 6h
{% if vault_github_token is defined and vault_github_token | length > 0 %}
            token: ${GLANCE_GITHUB_TOKEN}   # 5000 req/hr authenticated vs 60 unauthenticated
{% endif %}
            repositories:
              - jellyfin/jellyfin
              - seerr-team/seerr
              - Sonarr/Sonarr
              - Radarr/Radarr
              - Prowlarr/Prowlarr
              - morpheus65535/bazarr
              - recyclarr/recyclarr
              - advplyr/audiobookshelf
              # LazyLibrarian is GitLab-hosted (no GitHub releases) → not trackable by this widget
              - jorenn92/Maintainerr        # adjust if the repo path 404s
              - qbittorrent/qBittorrent
              - qdm12/gluetun
              - louislam/uptime-kuma
              - henrygd/beszel
              - amir20/dozzle
              - louislam/dockge
              - nicholas-fedor/watchtower
              - glanceapp/glance
              - NginxProxyManager/nginx-proxy-manager

  # ══ Page 2: Services — the application stack, health at a glance ══
  - name: Services
    columns:
      - size: full
        widgets:
          - type: monitor
            title: Media Stack
            cache: 1m
            sites:
              - title: Jellyfin
                url: http://{{ vault_beelink_host }}:8096
                icon: di:jellyfin
              - title: Seerr
                url: http://{{ vault_beelink_host }}:5055
                icon: di:seerr
              - title: Sonarr
                url: http://{{ vault_beelink_host }}:8989
                icon: di:sonarr
              - title: Radarr
                url: http://{{ vault_beelink_host }}:7878
                icon: di:radarr
              - title: Prowlarr
                url: http://{{ vault_beelink_host }}:9696
                icon: di:prowlarr
              - title: Bazarr
                url: http://{{ vault_beelink_host }}:6767
                icon: di:bazarr
              - title: LazyLibrarian
                url: http://{{ vault_beelink_host }}:5299
                icon: di:lazylibrarian
              - title: Audiobookshelf
                url: http://{{ vault_beelink_host }}:13378
                icon: di:audiobookshelf
              - title: Maintainerr
                url: http://{{ vault_beelink_host }}:6246
                icon: di:maintainerr
              - title: qBittorrent
                url: http://{{ vault_beelink_host }}:8080
                icon: di:qbittorrent

          - type: monitor
            title: Infrastructure
            cache: 1m
            sites:
              - title: Nginx Proxy Manager
                url: http://{{ vault_beelink_host }}:81
                icon: di:nginx-proxy-manager
              - title: Uptime Kuma
                url: http://{{ vault_beelink_host }}:3001
                icon: di:uptime-kuma
              - title: Beszel
                url: http://{{ vault_beelink_host }}:8090
                icon: di:beszel

          - type: monitor
            title: Administration
            cache: 1m
            sites:
              - title: Dozzle
                url: http://{{ vault_beelink_host }}:8888
                icon: di:dozzle
              - title: Dockge
                url: http://{{ vault_beelink_host }}:5001
                icon: di:dockge

  - name: Containers
    columns:
      - size: full
        widgets:
          # Live run-state of EVERY container (reads docker.sock :ro). This is where headless
          # Watchtower gets its dashboard presence; per-container display comes from glance.* labels.
          - type: docker-containers
            title: Containers
            cache: 30s
            hide-by-default: false
