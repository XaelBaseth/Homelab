services:
  glance:
    image: {{ glance_image }}
    container_name: glance
    ports:
      - 8280:8080
    volumes:
      - ./config/glance.yml:/app/config/glance.yml
      - /data:/mnt/host/data:ro     # media drive, for disk stats
      - /home:/mnt/host/home:ro     # docker + appdata, for disk stats
    restart: unless-stopped
