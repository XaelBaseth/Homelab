services:
  audiobookshelf:
    image: {{ audiobookshelf_image }}
    container_name: audiobookshelf
    environment:
      - TZ={{ timezone }}
    ports:
      - {{ audiobookshelf_port }}:80        # ABS listens on :80 inside the container
    volumes:
      - {{ audiobookshelf_appdata }}/config:/config       # DB + settings (root-owned; ABS is not a PUID/PGID image)
      - {{ audiobookshelf_appdata }}/metadata:/metadata   # covers, cached metadata, backups
      - {{ media_root }}/media/audiobooks:/audiobooks     # the library — filled by LazyLibrarian's hardlink imports
    restart: unless-stopped
